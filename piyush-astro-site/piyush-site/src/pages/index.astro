---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Piyush — The King" description="Full-Stack Architect. Visionary by nature.">

  <style>
    /* ── Navigation ── */
    #navbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      background: rgba(8,12,20,0.85);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(201,168,76,0.1);
      height: 68px; display: flex; align-items: center;
    }
    .nav-inner {
      max-width: 1200px; margin: 0 auto; padding: 0 24px;
      width: 100%; display: flex; align-items: center; justify-content: space-between;
    }
    .nav-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 22px; font-weight: 700; letter-spacing: 3px;
      text-decoration: none; color: var(--text);
    }
    .nav-links { display: flex; gap: 36px; align-items: center; }
    .nav-link {
      position: relative; background: none; border: none;
      color: rgba(232,230,224,0.6);
      font-family: 'DM Sans', sans-serif;
      font-size: 12px; font-weight: 500;
      letter-spacing: 1.5px; text-transform: uppercase;
      cursor: pointer; padding: 4px 0;
      transition: color 0.25s; text-decoration: none;
    }
    .nav-link::after {
      content: ''; position: absolute; bottom: -4px; left: 0;
      width: 0; height: 1px; background: var(--gold);
      transition: width 0.3s ease;
    }
    .nav-link:hover, .nav-link.active { color: var(--gold); }
    .nav-link:hover::after, .nav-link.active::after { width: 100%; }
    .nav-blog-btn {
      display: inline-flex; align-items: center; gap: 6px;
      background: rgba(201,168,76,0.1);
      border: 1px solid rgba(201,168,76,0.3);
      color: #C9A84C;
      font-family: 'DM Sans', sans-serif;
      font-size: 11px; font-weight: 500; letter-spacing: 1.5px; text-transform: uppercase;
      border-radius: 100px; padding: 6px 14px;
      text-decoration: none; transition: background 0.2s;
    }
    .nav-blog-btn:hover { background: rgba(201,168,76,0.18); }
    #hamburger { display: none; background: none; border: none; color: var(--text); cursor: pointer; padding: 4px; }
    #mobile-menu {
      display: none; flex-direction: column; gap: 4px;
      padding: 12px 24px 20px;
      border-top: 1px solid rgba(201,168,76,0.1);
      background: rgba(8,12,20,0.97);
    }
    #mobile-menu.open { display: flex; }
    .mobile-nav-link {
      background: none; border: none; color: var(--text);
      font-family: 'DM Sans', sans-serif; font-size: 15px;
      text-align: left; cursor: pointer; padding: 10px 0;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      text-decoration: none; transition: color 0.2s;
    }
    .mobile-nav-link:hover { color: var(--gold); }

    /* ── Hero ── */
    #home {
      min-height: 100vh; display: flex; align-items: center; justify-content: center;
      position: relative; overflow: hidden; padding: 100px 24px 60px;
    }
    .hero-ring {
      position: absolute; top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      border-radius: 50%; border: 1px solid rgba(201,168,76,0.05);
      pointer-events: none;
    }
    .ring-spin-cw  { animation: spin-cw  22s linear infinite; }
    .ring-spin-ccw { animation: spin-ccw 30s linear infinite; }
    @keyframes spin-cw  { from{transform:translate(-50%,-50%) rotate(0deg)}   to{transform:translate(-50%,-50%) rotate(360deg)} }
    @keyframes spin-ccw { from{transform:translate(-50%,-50%) rotate(0deg)}   to{transform:translate(-50%,-50%) rotate(-360deg)} }
    .hero-glow-l { position: absolute; top: 20%; left: 8%; width: 420px; height: 420px; border-radius: 50%; background: radial-gradient(circle, rgba(201,168,76,0.07) 0%, transparent 70%); pointer-events: none; }
    .hero-glow-r { position: absolute; bottom: 18%; right: 6%; width: 300px; height: 300px; border-radius: 50%; background: radial-gradient(circle, rgba(56,189,248,0.05) 0%, transparent 70%); pointer-events: none; }
    .hero-badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(201,168,76,0.1); border: 1px solid rgba(201,168,76,0.3);
      border-radius: 100px; padding: 6px 18px; margin-bottom: 32px;
      font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: var(--gold);
    }
    .crown-dot { width: 6px; height: 6px; background: var(--gold); border-radius: 50%; display: inline-block; }
    .hero-name { font-family: 'Cormorant Garamond', serif; font-size: clamp(62px, 13vw, 134px); font-weight: 700; line-height: 0.9; letter-spacing: -2px; color: var(--text); }
    .hero-subtitle { font-family: 'Cormorant Garamond', serif; font-style: italic; font-weight: 300; font-size: clamp(18px, 3.5vw, 36px); letter-spacing: 10px; margin-top: 14px; }
    .hero-tagline { margin-top: 28px; font-size: clamp(14px, 2vw, 17px); color: var(--text-muted); max-width: 500px; margin-left: auto; margin-right: auto; line-height: 1.8; font-weight: 300; }
    .btn-primary {
      display: inline-flex; align-items: center; gap: 8px;
      background: linear-gradient(135deg, #C9A84C, #F0D080); color: var(--navy);
      font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 600; letter-spacing: 1px;
      border: none; border-radius: 8px; padding: 14px 30px; cursor: pointer;
      transition: opacity 0.2s, transform 0.2s; text-decoration: none;
    }
    .btn-primary:hover { opacity: 0.88; transform: translateY(-2px); }
    .btn-outline {
      display: inline-flex; align-items: center; gap: 8px; background: transparent;
      border: 1px solid rgba(201,168,76,0.4); color: var(--gold);
      font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 500; letter-spacing: 1px;
      border-radius: 8px; padding: 14px 30px; cursor: pointer;
      transition: background 0.2s, transform 0.2s; text-decoration: none;
    }
    .btn-outline:hover { background: rgba(201,168,76,0.08); transform: translateY(-2px); }
    .scroll-cue { margin-top: 72px; display: flex; flex-direction: column; align-items: center; gap: 6px; color: rgba(232,230,224,0.25); animation: glow-pulse 3s ease-in-out infinite; }
    .scroll-cue span { font-size: 10px; letter-spacing: 3px; text-transform: uppercase; }

    /* ── Animations ── */
    @keyframes float      { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-10px)} }
    @keyframes glow-pulse { 0%,100%{opacity:0.4} 50%{opacity:1} }
    @keyframes fade-up    { from{opacity:0;transform:translateY(30px)} to{opacity:1;transform:translateY(0)} }
    .fade-up { opacity: 0; }
    .fade-up.visible { animation: fade-up 0.7s ease forwards; }
    .float-anim { animation: float 6s ease-in-out infinite; }

    /* ── Sections ── */
    .section-wrap { max-width: 1200px; margin: 0 auto; padding: 110px 24px; }
    .divider { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
    .divider-line { height: 1px; background: linear-gradient(90deg, transparent, rgba(201,168,76,0.2), transparent); }
    .section-label { font-size: 11px; letter-spacing: 3px; color: var(--gold); text-transform: uppercase; margin-bottom: 14px; }
    .section-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(38px, 5vw, 60px); font-weight: 700; line-height: 1.05; }

    /* ── About ── */
    .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
    .stat-num { font-family: 'Cormorant Garamond', serif; font-size: 44px; font-weight: 700; line-height: 1; }
    .stat-lbl { font-size: 11px; color: rgba(232,230,224,0.35); letter-spacing: 1px; margin-top: 4px; }
    .code-card { border-radius: 16px; background: linear-gradient(135deg, rgba(201,168,76,0.08), rgba(56,189,248,0.04)); border: 1px solid rgba(201,168,76,0.13); padding: 3px; }
    .code-card-inner { border-radius: 14px; background: linear-gradient(160deg, #0D1520 0%, #0A1018 100%); padding: 36px; min-height: 340px; display: flex; flex-direction: column; justify-content: space-between; }
    .code-dots { display: flex; gap: 6px; margin-bottom: 24px; }
    .code-dot { width: 10px; height: 10px; border-radius: 50%; }
    .code-line { font-family: 'Courier New', monospace; font-size: 13px; line-height: 2; display: flex; flex-wrap: wrap; gap: 4px; }
    .c-punct { color: rgba(232,230,224,0.4); } .c-key { color: #38BDF8; } .c-var { color: #34D399; } .c-str { color: var(--gold); }
    .badge-pill { background: rgba(201,168,76,0.1); border: 1px solid rgba(201,168,76,0.25); border-radius: 100px; padding: 4px 13px; font-size: 11px; color: var(--gold); letter-spacing: 1px; }

    /* ── Projects ── */
    .projects-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 22px; }
    .project-card { background: linear-gradient(135deg, #0D1520, #0A1018); border: 1px solid rgba(255,255,255,0.07); border-radius: 16px; overflow: hidden; cursor: pointer; transition: transform 0.3s ease, box-shadow 0.3s ease; }
    .project-card:hover { transform: translateY(-7px); box-shadow: 0 28px 56px rgba(0,0,0,0.55); }
    .project-header { padding: 26px 26px 0; }
    .project-icon-wrap { display: inline-flex; padding: 10px; background: rgba(0,0,0,0.3); border-radius: 10px; }
    .project-fade { height: 72px; background: linear-gradient(180deg, transparent, #0D1520); }
    .project-body { padding: 0 26px 26px; }
    .project-title { font-family: 'Cormorant Garamond', serif; font-size: 21px; font-weight: 700; margin-bottom: 10px; letter-spacing: -0.3px; }
    .project-desc { font-size: 13.5px; color: var(--text-muted); line-height: 1.7; margin-bottom: 18px; }
    .tag-pill { font-size: 11px; border-radius: 100px; padding: 3px 10px; letter-spacing: 0.5px; }

    /* ── Skills ── */
    .skills-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 24px; }
    .skill-card { background: var(--navy-card); border: 1px solid rgba(255,255,255,0.06); border-radius: 14px; padding: 26px 26px 22px; }
    .skill-bar-track { height: 8px; border-radius: 100px; background: rgba(255,255,255,0.08); overflow: hidden; }
    .skill-bar-fill { height: 100%; border-radius: 100px; width: 0; transition: width 1.1s cubic-bezier(.4,0,.2,1); }
    .skill-tick { font-size: 10px; color: rgba(232,230,224,0.2); }
    .tech-pill { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 100px; padding: 6px 14px; font-size: 12px; color: rgba(232,230,224,0.45); letter-spacing: 0.4px; }

    /* ── Contact ── */
    .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start; }
    .contact-form-card { background: var(--navy-card); border: 1px solid rgba(201,168,76,0.1); border-radius: 20px; padding: 36px; }
    .form-label { font-size: 11px; color: rgba(232,230,224,0.38); letter-spacing: 1.5px; text-transform: uppercase; display: block; margin-bottom: 8px; }
    .form-input, .form-textarea { background: rgba(255,255,255,0.04); border: 1px solid rgba(201,168,76,0.18); border-radius: 8px; color: var(--text); padding: 12px 16px; width: 100%; font-family: 'DM Sans', sans-serif; font-size: 14px; outline: none; transition: border-color 0.2s; }
    .form-input:focus, .form-textarea:focus { border-color: var(--gold); }
    .form-input::placeholder, .form-textarea::placeholder { color: rgba(255,255,255,0.25); }
    .form-textarea { resize: vertical; min-height: 120px; }
    .social-row { display: flex; align-items: center; gap: 14px; color: var(--text-muted); text-decoration: none; transition: color 0.22s; }
    .social-row:hover { color: var(--gold); }
    .social-icon-wrap { padding: 10px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; display: flex; align-items: center; justify-content: center; transition: border-color 0.22s; }
    .social-row:hover .social-icon-wrap { border-color: rgba(201,168,76,0.3); }

    /* ── Toast ── */
    #toast { position: fixed; bottom: 32px; right: 32px; z-index: 999; background: linear-gradient(135deg, #C9A84C, #F0D080); color: var(--navy); font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 600; letter-spacing: 0.5px; padding: 14px 22px; border-radius: 10px; display: flex; align-items: center; gap: 8px; box-shadow: 0 8px 32px rgba(201,168,76,0.35); transform: translateY(80px); opacity: 0; transition: transform 0.4s ease, opacity 0.4s ease; }
    #toast.show { transform: translateY(0); opacity: 1; }

    footer { border-top: 1px solid rgba(255,255,255,0.06); padding: 32px 24px; text-align: center; }
    .footer-logo { font-family: 'Cormorant Garamond', serif; font-size: 20px; font-weight: 700; letter-spacing: 4px; }

    @media (max-width: 768px) {
      .nav-links { display: none; }
      #hamburger { display: block; }
      .about-grid { grid-template-columns: 1fr; gap: 48px; }
      .contact-grid { grid-template-columns: 1fr; gap: 48px; }
      .hero-name { letter-spacing: -1px; }
      .section-wrap { padding: 80px 20px; }
    }
  </style>

  <!-- NAVBAR -->
  <header id="navbar">
    <div class="nav-inner">
      <a href="/" class="nav-logo"><span class="gold-gradient">P</span>IYUSH</a>
      <nav class="nav-links" id="nav-links">
        <a href="#home"     class="nav-link active" data-section="home">Home</a>
        <a href="#about"    class="nav-link" data-section="about">About</a>
        <a href="#projects" class="nav-link" data-section="projects">Projects</a>
        <a href="#skills"   class="nav-link" data-section="skills">Skills</a>
        <a href="#contact"  class="nav-link" data-section="contact">Contact</a>
        <a href="/blog" class="nav-blog-btn">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          Blog
        </a>
      </nav>
      <button id="hamburger" aria-label="Toggle menu">
        <svg id="icon-menu"  width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        <svg id="icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="display:none"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div id="mobile-menu">
      <a href="#home"     class="mobile-nav-link">Home</a>
      <a href="#about"    class="mobile-nav-link">About</a>
      <a href="#projects" class="mobile-nav-link">Projects</a>
      <a href="#skills"   class="mobile-nav-link">Skills</a>
      <a href="#contact"  class="mobile-nav-link">Contact</a>
      <a href="/blog"     class="mobile-nav-link" style="color:#C9A84C;">Blog</a>
    </div>
  </header>

  <!-- HERO -->
  <section id="home">
    <div class="hero-glow-l"></div>
    <div class="hero-glow-r"></div>
    <div class="hero-ring ring-spin-cw"  style="width:580px;height:580px;"></div>
    <div class="hero-ring ring-spin-ccw" style="width:800px;height:800px;border-style:dashed;opacity:.5"></div>
    <div class="hero-ring" style="width:1050px;height:1050px;opacity:.25"></div>
    <div style="text-align:center;position:relative;z-index:1;">
      <div class="hero-badge float-anim"><span class="crown-dot"></span>Available for Elite Projects<span class="crown-dot"></span></div>
      <h1 class="hero-name">PIYUSH</h1>
      <p class="hero-subtitle gold-gradient">— The King —</p>
      <p class="hero-tagline">Crafting digital empires with code, design, and relentless precision.<br/>Full-Stack Architect by day. Visionary by nature.</p>
      <div style="display:flex;gap:16px;justify-content:center;margin-top:44px;flex-wrap:wrap;">
        <a href="#projects" class="btn-primary">View My Work <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></a>
        <a href="#contact" class="btn-outline">Get In Touch</a>
      </div>
      <div class="scroll-cue"><span>Scroll</span><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="section-wrap">
    <div class="about-grid fade-up">
      <div>
        <p class="section-label">About Me</p>
        <h2 class="section-title" style="margin-bottom:26px;">Built to <span class="gold-gradient">Reign</span>,<br>Engineered to <em style="color:var(--text-muted);font-style:italic;">Endure</em></h2>
        <div style="color:var(--text-muted);line-height:1.9;font-size:15px;display:flex;flex-direction:column;gap:16px;">
          <p>I'm Piyush — a Full-Stack Developer and Systems Architect with a decade of experience turning ambitious ideas into battle-hardened digital products.</p>
          <p>From founding-stage startups to Fortune 500 systems, I've led the architecture of platforms that scale to millions. I believe the best code is invisible — it simply works, gracefully, at any load.</p>
          <p>When I'm not in a terminal, I'm mentoring engineers, obsessing over typography, or brewing the perfect cup before a deep work session.</p>
        </div>
        <div style="display:flex;gap:40px;margin-top:40px;flex-wrap:wrap;">
          <div><div class="stat-num gold-gradient">10+</div><div class="stat-lbl">Years Exp.</div></div>
          <div><div class="stat-num gold-gradient">50+</div><div class="stat-lbl">Projects</div></div>
          <div><div class="stat-num gold-gradient">12</div><div class="stat-lbl">Awards</div></div>
        </div>
      </div>
      <div style="position:relative;">
        <div class="code-card">
          <div class="code-card-inner">
            <div>
              <div class="code-dots"><div class="code-dot" style="background:#FF5F57;"></div><div class="code-dot" style="background:#FEBC2E;"></div><div class="code-dot" style="background:#28C840;"></div></div>
              <div style="display:flex;flex-direction:column;gap:2px;">
                <div class="code-line"><span class="c-punct">&gt;&nbsp;</span><span class="c-key">const</span><span class="c-var">&nbsp;piyush</span><span class="c-punct">&nbsp;= &#123;</span></div>
                <div class="code-line"><span class="c-punct">&nbsp;&nbsp;title:&nbsp;</span><span class="c-str">"The King"</span><span class="c-punct">,</span></div>
                <div class="code-line"><span class="c-punct">&nbsp;&nbsp;role:&nbsp;</span><span class="c-str">"Full-Stack Architect"</span><span class="c-punct">,</span></div>
                <div class="code-line"><span class="c-punct">&nbsp;&nbsp;passion:&nbsp;</span><span class="c-str">"Building legacies"</span><span class="c-punct">,</span></div>
                <div class="code-line"><span class="c-punct">&nbsp;&nbsp;status:&nbsp;</span><span class="c-str">"Open to work"</span><span class="c-punct">,</span></div>
                <div class="code-line"><span class="c-punct">&nbsp;&nbsp;superpower:&nbsp;</span><span class="c-str">"Ships fast"</span><span class="c-punct">,</span></div>
                <div class="code-line"><span class="c-punct">&#125;</span></div>
              </div>
            </div>
            <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:28px;">
              <span class="badge-pill">Thinker</span><span class="badge-pill">Builder</span><span class="badge-pill">Leader</span><span class="badge-pill">Creator</span>
            </div>
          </div>
        </div>
        <div style="position:absolute;top:-18px;right:-18px;width:90px;height:90px;border-radius:50%;background:radial-gradient(circle,rgba(201,168,76,0.18) 0%,transparent 70%);pointer-events:none;animation:glow-pulse 3s ease-in-out infinite;"></div>
      </div>
    </div>
  </section>

  <div class="divider"><div class="divider-line"></div></div>

  <!-- PROJECTS -->
  <section id="projects" class="section-wrap">
    <div class="fade-up" style="margin-bottom:56px;"><p class="section-label">Selected Work</p><h2 class="section-title">Royal <span class="gold-gradient">Projects</span></h2></div>
    <div class="projects-grid">
      <article class="project-card fade-up">
        <div class="project-header" style="background:linear-gradient(135deg,rgba(245,158,11,0.18),rgba(234,179,8,0.06));">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;">
            <div class="project-icon-wrap" style="border:1px solid rgba(245,158,11,0.25);color:#F59E0B;"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/></svg></div>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="rgba(232,230,224,0.25)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
