---
import BaseLayout from './BaseLayout.astro';
export interface Props {
  title: string;
  date: Date;
  author: string;
  tags?: string[];
  cover_image?: string;
}
const { title, date, author, tags, cover_image } = Astro.props;
const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric'
});
---
<BaseLayout title={`${title} — Piyush`}>
  <style>
    .post-nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      background: rgba(8,12,20,0.9);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(201,168,76,0.1);
      height: 64px; display: flex; align-items: center;
    }
    .post-nav-inner {
      max-width: 860px; margin: 0 auto; padding: 0 24px;
      width: 100%; display: flex; align-items: center; justify-content: space-between;
    }
    .back-link {
      display: inline-flex; align-items: center; gap: 8px;
      color: rgba(232,230,224,0.5); text-decoration: none;
      font-family: 'DM Sans', sans-serif; font-size: 13px;
      letter-spacing: 1px; text-transform: uppercase;
      transition: color 0.2s;
    }
    .back-link:hover { color: #C9A84C; }
    .post-wrap {
      max-width: 860px; margin: 0 auto;
      padding: 110px 24px 100px;
    }
    .post-cover {
      width: 100%; height: 400px; object-fit: cover;
      border-radius: 16px; margin-bottom: 48px;
      border: 1px solid rgba(201,168,76,0.1);
    }
    .post-meta {
      display: flex; align-items: center; gap: 20px;
      margin-bottom: 20px; flex-wrap: wrap;
    }
    .post-date {
      font-family: 'DM Sans', sans-serif;
      font-size: 12px; letter-spacing: 2px; text-transform: uppercase;
      color: #C9A84C;
    }
    .post-author {
      font-family: 'DM Sans', sans-serif;
      font-size: 12px; color: rgba(232,230,224,0.4); letter-spacing: 1px;
    }
    .post-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(36px, 5vw, 58px);
      font-weight: 700; line-height: 1.05;
      margin-bottom: 28px; letter-spacing: -0.5px;
    }
    .post-tags { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 48px; }
    .post-tag {
      font-family: 'DM Sans', sans-serif;
      font-size: 11px; letter-spacing: 1px;
      background: rgba(201,168,76,0.1);
      border: 1px solid rgba(201,168,76,0.25);
      color: #C9A84C; border-radius: 100px; padding: 4px 12px;
    }
    .post-divider {
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(201,168,76,0.2), transparent);
      margin-bottom: 48px;
    }

    /* ── Markdown content styles ── */
    .prose { color: rgba(232,230,224,0.75); line-height: 1.85; font-size: 16px; }
    .prose h1, .prose h2, .prose h3, .prose h4 {
      font-family: 'Cormorant Garamond', serif;
      color: #E8E6E0; font-weight: 700; margin: 2em 0 0.75em;
      line-height: 1.1;
    }
    .prose h1 { font-size: 40px; }
    .prose h2 { font-size: 32px; border-bottom: 1px solid rgba(201,168,76,0.15); padding-bottom: 10px; }
    .prose h3 { font-size: 24px; }
    .prose p  { margin: 0 0 1.5em; }
    .prose a  { color: #C9A84C; text-decoration: underline; text-decoration-color: rgba(201,168,76,0.4); transition: color 0.2s; }
    .prose a:hover { color: #F0D080; }
    .prose strong { color: #E8E6E0; font-weight: 600; }
    .prose em { color: rgba(232,230,224,0.65); font-style: italic; }
    .prose ul, .prose ol { padding-left: 1.5em; margin: 0 0 1.5em; display: flex; flex-direction: column; gap: 6px; }
    .prose li { color: rgba(232,230,224,0.7); }
    .prose blockquote {
      border-left: 3px solid #C9A84C;
      margin: 2em 0; padding: 16px 24px;
      background: rgba(201,168,76,0.05);
      border-radius: 0 8px 8px 0;
      font-style: italic; color: rgba(232,230,224,0.6);
    }
    .prose code {
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 4px; padding: 2px 6px;
      font-family: 'Courier New', monospace; font-size: 13px;
      color: #34D399;
    }
    .prose pre {
      background: #0D1520;
      border: 1px solid rgba(201,168,76,0.1);
      border-radius: 10px; padding: 24px;
      overflow-x: auto; margin: 0 0 1.5em;
    }
    .prose pre code {
      background: none; border: none; padding: 0;
      font-size: 14px; line-height: 1.7;
    }
    .prose img {
      width: 100%; border-radius: 10px; margin: 1.5em 0;
      border: 1px solid rgba(201,168,76,0.1);
    }
    .prose hr {
      border: none;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(201,168,76,0.2), transparent);
      margin: 3em 0;
    }
    .prose table { width: 100%; border-collapse: collapse; margin: 0 0 1.5em; font-size: 14px; }
    .prose th {
      background: rgba(201,168,76,0.1); color: #C9A84C;
      padding: 10px 16px; text-align: left; font-weight: 600;
      border: 1px solid rgba(201,168,76,0.15);
    }
    .prose td {
      padding: 10px 16px; border: 1px solid rgba(255,255,255,0.06);
      color: rgba(232,230,224,0.65);
    }
    .prose tr:nth-child(even) td { background: rgba(255,255,255,0.02); }

    footer {
      border-top: 1px solid rgba(255,255,255,0.06);
      padding: 32px 24px; text-align: center; margin-top: 80px;
    }
  </style>

  <!-- Sticky nav -->
  <nav class="post-nav">
    <div class="post-nav-inner">
      <a href="/blog" class="back-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        All Posts
      </a>
      <a href="/" class="font-display gold-gradient" style="font-size:18px;font-weight:700;letter-spacing:3px;text-decoration:none;">PIYUSH</a>
    </div>
  </nav>

  <!-- Post content -->
  <article class="post-wrap">
    {cover_image && <img src={cover_image} alt={title} class="post-cover" />}

    <div class="post-meta">
      <span class="post-date">{formattedDate}</span>
      <span class="post-author">by {author}</span>
    </div>

    <h1 class="post-title">{title}</h1>

    {tags && tags.length > 0 && (
      <div class="post-tags">
        {tags.map(tag => <span class="post-tag">{tag}</span>)}
      </div>
    )}

    <div class="post-divider"></div>

    <div class="prose">
      <slot />
    </div>
  </article>

  <footer>
    <div class="font-display gold-gradient" style="font-size:18px;font-weight:700;letter-spacing:4px;">PIYUSH</div>
    <p style="font-size:12px;color:rgba(232,230,224,0.22);letter-spacing:1px;margin-top:8px;">
      &copy; {new Date().getFullYear()} &nbsp;·&nbsp; Crafted with precision
    </p>
  </footer>
</BaseLayout>
